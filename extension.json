{
  "id": "com.vpnpoppy.desktop",
  "name": "VPN-Poppy",
  "version": "0.1.0",
  "description": "A personal VPN on the fly in your own AWS — one-click WireGuard endpoints on a t4g.nano, no SSH, QR/.conf for unlimited devices, live cost meter, teardown whenever or after N hours you set.",
  "icon": "frontend/vpnpoppy-icon.png",
  "permissionSet": {
    "id": "vpnpoppy-backend",
    "name": "VPN-Poppy backend",
    "description": "Launch and manage a single EC2 endpoint it creates, scoped to its own tagged resources. Reads/creates on EC2; every change or delete is limited to instances and security groups tagged as its own. Reads CloudWatch metrics for the cost meter. No IAM, no key pairs, no account/org access.",
    "requiredTags": ["agentspoppy:account", "agentspoppy:app", "agentspoppy:connection"],
    "grants": [
      {
        "service": "ec2",
        "actions": [
          "DescribeInstances",
          "DescribeImages",
          "DescribeVpcs",
          "DescribeSubnets",
          "DescribeSecurityGroups"
        ],
        "resourceScope": "*"
      },
      {
        "service": "ec2",
        "actions": [
          "RunInstances",
          "CreateSecurityGroup",
          "CreateTags"
        ],
        "resourceScope": "*"
      },
      {
        "service": "ec2",
        "actions": [
          "AuthorizeSecurityGroupIngress",
          "TerminateInstances",
          "DeleteSecurityGroup",
          "GetConsoleOutput"
        ],
        "resourceScope": "tagged-as-self"
      },
      {
        "service": "cloudwatch",
        "actions": ["GetMetricData"],
        "resourceScope": "*"
      }
    ],
    "limits": null
  },
  "frontend": {
    "entry": "frontend/index.html"
  },
  "backend": {
    "entry": "backend/vpnpoppy-sidecar",
    "transport": "http"
  },
  "teardown": {
    "endpoint": "/teardown"
  },
  "capabilities": [
    "aws:credentials",
    "connection:read",
    "backend:invoke",
    "host:openExternal",
    "host:notify"
  ]
}
